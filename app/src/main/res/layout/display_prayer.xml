<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:layoutDirection="rtl"
    android:background="@drawable/background_image">

    <!-- Top panel: Title and back button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:padding="4dp"
        android:background="@android:color/transparent">


        <Button
            android:id="@+id/back"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="bottom|left"
            android:layout_margin="8dp"
            android:background="@drawable/button_back"
            android:text="" />

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="60dp"
            android:paddingEnd="60dp"
            android:lineSpacingExtra="4dp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:text="تساعية مار شربل"
            android:textSize="19sp"
            android:background="@android:color/transparent"/>
    </FrameLayout>

    <!-- Content: Scrollable text -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:background="@android:color/transparent">

        <TextView
            android:id="@+id/data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="#000000"
            android:text="@string/saintCharbel"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"/>

    </ScrollView>

    <!-- Bottom panel: Font size controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="51dp"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/decreaseFontSize"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:text="A-"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/currentFontSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="16"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/increaseFontSize"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:text="A+"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>