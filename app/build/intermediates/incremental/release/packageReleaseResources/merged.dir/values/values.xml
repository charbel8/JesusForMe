<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">#FF6200EE</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="teal_200">#FF03DAC5</color>
    <color name="teal_700">#FF018786</color>
    <color name="white">#FFFFFFFF</color>
    <string name="app_name">Jesus for me</string>
    <string name="app_version">version 1.5</string>
    <string name="saintCharbel">اليوم الأول:\(أبانا والسلام والمجد)\r</string>
    <style name="ExpendButton">
          <item name="android:layout_width">match_parent</item>
          <item name="android:layout_height">wrap_content</item>
          <item name="android:textAlignment">textStart</item>
          <item name="android:paddingStart">16dp</item>
          <item name="android:paddingEnd">16dp</item>
          <item name="android:background">?attr/selectableItemBackground</item>
          <item name="android:textColor">#2196F3</item>
          <item name="android:textAllCaps">false</item>
          <item name="android:textSize">16sp</item>
          <item name="android:textStyle">bold</item>
    </style>
    <style name="GridButton">
    <item name="android:layout_width">0dp</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_weight">1</item>
    <item name="android:layout_margin">4dp</item>
    <item name="android:textStyle">bold</item>
    <item name="android:textColor">#000000</item>
    <item name="android:background">@drawable/button_border</item>
</style>
    <style name="LinearExpand">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <style name="RawButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>
    <style name="Theme.JesusForMe" parent="Theme.AppCompat.Light.NoActionBar">
            
            <item name="colorPrimary">#EFE0CA</item>
            <item name="colorPrimaryDark">#EFE0CA</item>
            <item name="colorAccent">#EFE0CA</item>
        </style>
    <style name="appVersionText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center</item>
         <item name="android:textSize">12sp</item>
         <item name="android:textColor">#666666</item>
         <item name="android:padding">8dp</item>
    </style>
</resources>